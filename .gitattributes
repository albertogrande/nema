# SPDX-License-Identifier: Apache-2.0
# Normalize line endings to LF on commit, regardless of contributor OS.
* text=auto eol=lf

# Generated / vendored files: collapse diffs and keep them out of language stats.
pnpm-lock.yaml      linguist-generated=true -diff
LICENSES/**         linguist-generated=true
*.svg               linguist-detectable=false

# Binary assets — never normalize or diff as text.
*.png   binary
*.ico   binary
*.woff  binary
*.woff2 binary
