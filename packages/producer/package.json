{
  "name": "@getnema/producer",
  "version": "0.4.0",
  "description": "Nema producer loop: draft -> branch -> PR -> approve -> state-flip, over a NemaHost",
  "license": "Apache-2.0",
  "type": "module",
  "author": "Alberto Grande",
  "homepage": "https://github.com/albertogrande/nema#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/albertogrande/nema.git",
    "directory": "packages/producer"
  },
  "bugs": {
    "url": "https://github.com/albertogrande/nema/issues"
  },
  "keywords": [
    "documentation",
    "docs-as-code",
    "ai",
    "agents",
    "provenance",
    "mcp"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@getnema/core": "workspace:*",
    "@getnema/drift": "workspace:*",
    "@getnema/gates": "workspace:*",
    "@getnema/provenance": "workspace:*",
    "@getnema/schema": "workspace:*",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
