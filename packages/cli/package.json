{
  "name": "@nema/cli",
  "version": "0.1.0-alpha.0",
  "description": "Nema CLI — the `nema` binary (init/check/draft/open-pr/approve/prov/mcp)",
  "license": "Apache-2.0",
  "type": "module",
  "author": "Alberto Grande",
  "homepage": "https://github.com/albertogrande/nema#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/albertogrande/nema.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/albertogrande/nema/issues"
  },
  "keywords": ["documentation", "docs-as-code", "ai", "agents", "provenance", "mcp", "cli"],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "bin": {
    "nema": "./dist/index.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@nema/core": "workspace:*",
    "@nema/gates": "workspace:*",
    "@nema/mcp": "workspace:*",
    "@nema/producer": "workspace:*",
    "@nema/provenance": "workspace:*",
    "@nema/schema": "workspace:*",
    "citty": "^0.1.6"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
