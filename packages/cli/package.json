    "@getnema/mcp": "workspace:*",
    "@getnema/producer": "workspace:*",
    "@getnema/provenance": "workspace:*",
    "@getnema/schema": "workspace:*",
    "citty": "^0.1.6",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
