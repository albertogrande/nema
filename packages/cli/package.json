{
  "name": "@getnema/cli",
  "version": "0.1.0",
  "description": "Nema CLI — the `nema` binary (init/check/draft/open-pr/approve/prov/mcp)",
  "license": "Apache-2.0",
  "type": "module",
  "author": "Alberto Grande",
  "homepage": "https://github.com/albertogrande/nema#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/albertogrande/nema.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/albertogrande/nema/issues"
  },
  "keywords": [
    "documentation",
    "docs-as-code",
    "ai",
