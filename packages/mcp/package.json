{
  "name": "@nema/mcp",
  "version": "0.1.0-alpha.0",
  "description": "Nema MCP server: read tools + write tools (draft/update/propose/check/request_review)",
  "license": "Apache-2.0",
  "type": "module",
  "author": "Alberto Grande",
  "homepage": "https://github.com/albertogrande/nema#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/albertogrande/nema.git",
    "directory": "packages/mcp"
  },
  "bugs": {
    "url": "https://github.com/albertogrande/nema/issues"
  },
  "keywords": ["documentation", "docs-as-code", "ai", "agents", "provenance", "mcp"],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "bin": {
    "nema-mcp": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@nema/core": "workspace:*",
    "@nema/gates": "workspace:*",
    "@nema/producer": "workspace:*",
    "@nema/provenance": "workspace:*",
    "@nema/schema": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "gray-matter": "^4.0.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
