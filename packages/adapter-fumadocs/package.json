{
  "name": "@nema/adapter-fumadocs",
  "version": "0.1.0-alpha.0",
  "description": "Nema reference renderer adapter for Fumadocs (Next/React): render + .md route + nav + provenance badge",
  "license": "Apache-2.0",
  "type": "module",
  "author": "Alberto Grande",
  "homepage": "https://github.com/albertogrande/nema#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/albertogrande/nema.git",
    "directory": "packages/adapter-fumadocs"
  },
  "bugs": {
    "url": "https://github.com/albertogrande/nema/issues"
  },
  "keywords": ["documentation", "docs-as-code", "ai", "agents", "provenance", "fumadocs", "react"],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@nema/adapter-kit": "workspace:*",
    "@nema/core": "workspace:*",
    "@nema/schema": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true }
  },
  "devDependencies": {
    "@types/react": "^19.0.1",
    "react": "^19.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
